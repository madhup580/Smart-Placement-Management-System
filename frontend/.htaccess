# Cache Control for Development and Production
# This file works with Apache servers

# Disable caching for HTML files
<FilesMatch "\.(html|htm)$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
</FilesMatch>

# For development: disable caching for CSS and JS
# For production: use version query params (?v=X) for cache busting
<FilesMatch "\.(css|js)$">
    # Check if it's a development environment (you can customize this)
    # For now, we'll use version query params in HTML instead
    Header set Cache-Control "public, max-age=31536000, immutable"
    # But allow override with query params
</FilesMatch>

# Enable CORS for API requests (if needed)
<IfModule mod_headers.c>
    Header set Access-Control-Allow-Origin "*"
    Header set Access-Control-Allow-Methods "GET, POST, PUT, DELETE, OPTIONS"
    Header set Access-Control-Allow-Headers "Content-Type, Authorization"
</IfModule>

